OPENAI_API_KEY=...
LANGSMITH_TRACING=true
LANGSMITH_API_KEY=...
LANGSMITH_PROJECT=ReAct-Agent-Template
TAVILY_API_KEY=...

# LangGraph API
LANGGRAPH_API_URL=http://localhost:2024

# Upstage Embedding
UPSTAGE_API_KEY=...

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=app_db
DB_USER=app_user
DB_PASSWORD=password

# RAPTOR 2-stage retrieval (true/false)
ENABLE_RAPTOR=false

# Hybrid Search (BM25 + Dense)
ENABLE_HYBRID_SEARCH=false
HYBRID_ALPHA=0.7
BM25_TOP_K=20

# LangGraph API Authentication
# Generate with: openssl rand -hex 32
LANGGRAPH_AUTH_KEY=
