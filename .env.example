OPENAI_API_KEY=...
GOOGLE_API_KEY=...          # Gemini 모델 사용 시
XAI_API_KEY=...             # Grok 모델 사용 시

LANGSMITH_TRACING=true
LANGSMITH_API_KEY=...
LANGSMITH_PROJECT=ReAct-Agent-Template
TAVILY_API_KEY=...

# LangGraph API
LANGGRAPH_API_URL=http://localhost:2024

# Upstage Embedding
UPSTAGE_API_KEY=...

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=app_db
DB_USER=app_user
DB_PASSWORD=password

# Below settings are managed via admin UI (app_settings table):
# model, summarization_model, rag_grading_model,
# max_search_results, summary_message_threshold,
# enable_raptor, enable_hybrid_search, hybrid_alpha, bm25_top_k

# LangGraph API Authentication
# Generate with: openssl rand -hex 32
LANGGRAPH_AUTH_KEY=
